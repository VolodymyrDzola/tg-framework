{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ES2022",
    "moduleResolution": "node",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "node",
      "google-apps-script"
    ]
  },
  "include": [
    "src/**/*"
  ]
}